---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not Found — Studio Blog">
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center max-w-md px-6">
      <h1 class="font-head text-6xl md:text-8xl leading-tight mb-4">404</h1>
      <p class="text-lg text-muted-foreground mb-8">
        Page not found.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm font-bold border border-border bg-primary text-primary-foreground px-4 py-2 bk-press no-underline"
      >
        &larr; Back to the blog
      </a>
    </div>
  </div>
</Layout>
