---
import Layout from '../layouts/Layout.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import PageBody from '../components/tina/PageBody.astro';
import { islands } from '../lib/tina/islands';
import { getPage } from '../lib/tina/data';

const { slug } = Astro.params;
const result = await getPage(slug ?? '');
const page = result.data?.page;
if (!page) return Astro.redirect('/404');
---

<Layout title={`${page.title} — Studio Blog`}>
  <div class="min-h-screen">
    <!-- Top bar -->
    <div class="border-b-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm font-bold border border-border bg-primary text-primary-foreground px-3 py-1.5 bk-press no-underline"
        >
          &larr; Back to blog
        </a>
      </div>
    </div>

    <!-- Page with visual editing -->
    <TinaIsland name="page" wrapper={islands.page.wrapper} params={{ slug: slug ?? '' }} primary>
      <PageBody data={page} />
    </TinaIsland>

    <!-- Footer -->
    <footer class="border-t-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-8 text-center text-sm opacity-70">
        Studio Blog &copy; {new Date().getFullYear()}
      </div>
    </footer>
  </div>
</Layout>
