---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About — Studio Blog">
  <div class="min-h-screen">
    <!-- Top bar -->
    <div class="border-b-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm font-bold border border-border bg-primary text-primary-foreground px-3 py-1.5 bk-press no-underline"
        >
          &larr; Back to blog
        </a>
      </div>
    </div>

    <div class="max-w-3xl mx-auto px-6 py-12">
      <h1 class="font-head text-3xl md:text-5xl leading-tight mb-6">About</h1>
      <div class="prose">
        <p>
          Built by Chris Radd — a professional designer working across advertising campaigns, CPG packaging, websites, print, OOH, and motion. This blog is a space for thinking out loud, sharing process, and building in public.
        </p>
        <p>
          Studio Blog runs on <strong>Astro</strong>, <strong>BoldKit</strong>, and <strong>TinaCMS</strong> — deployed to <strong>Cloudflare Pages</strong>.
        </p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="border-t-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-8 text-center text-sm opacity-70">
        Studio Blog &copy; {new Date().getFullYear()}
      </div>
    </footer>
  </div>
</Layout>
