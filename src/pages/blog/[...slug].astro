---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const { Content } = await render(post);
---

<Layout title={`${title} — Studio Blog`} description={description}>
  <div class="min-h-screen">
    <!-- Top bar -->
    <div class="border-b-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-4">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm font-bold border border-border bg-primary text-primary-foreground px-3 py-1.5 bk-press no-underline"
        >
          &larr; Back to posts
        </a>
      </div>
    </div>

    <!-- Post -->
    <article class="mx-auto max-w-3xl px-6 py-12">
      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-3 text-sm font-medium text-muted-foreground mb-4">
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {tags.length > 0 && (
          <span class="flex gap-1.5 flex-wrap">
            {tags.map((tag) => (
              <span class="bg-primary text-primary-foreground px-2 py-0.5 text-xs font-bold border border-border">
                {tag}
              </span>
            ))}
          </span>
        )}
      </div>

      <!-- Title -->
      <h1 class="font-head text-3xl md:text-5xl leading-tight mb-6">
        {title}
      </h1>

      <!-- Content -->
      <div class="prose">
        <Content />
      </div>
    </article>

    <!-- Footer -->
    <footer class="border-t-3 border-border bg-secondary text-secondary-foreground">
      <div class="mx-auto max-w-4xl px-6 py-8 text-center text-sm opacity-70">
        Studio Blog &copy; {new Date().getFullYear()}
      </div>
    </footer>
  </div>
</Layout>
